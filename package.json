  "repository": {
    "type": "git",
    "url": "git+https://github.com/DAAF-Contribution-Community/daaf-omp.git"
  },
  "keywords": [
    "omp",
    "oh-my-pi",
    "daaf",
    "data-analysis",
    "agentic"
  ],
  "author": "DAAF Contribution Community",
  "license": "LGPL-3.0-or-later",
  "omp": {
    "name": "daaf-omp",
    "version": "1.0.0",
