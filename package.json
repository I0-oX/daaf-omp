      "./.omp/extensions/daaf-archive-session.ts",
      "./.omp/extensions/daaf-recover-session-logs.ts",
      "./.omp/extensions/daaf-flag-orchestrator-loaded.ts",
      "./.omp/extensions/daaf-deny-claude-code-guide.ts",
